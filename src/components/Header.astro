---
import { translations, languages } from '../i18n/translations';

interface Props {
  lang: string;
  variant?: 'overlay' | 'solid';
}

const { lang, variant = 'overlay' } = Astro.props;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const pathWithoutLang = pathSegments.slice(1).join('/') || '';
---

<header class={`alba-header ${variant === 'overlay' ? 'overlay' : 'solid'}`} id="alba-header">
  <div class="alba-header-inner">
    <!-- Logo top-left -->
    <a href={`/${langKey}/`} class="alba-brand" aria-label="MAISON ALBA">
      <span class="brand-mark">M·A</span>
      <span class="brand-name">Maison Alba</span>
    </a>

    <!-- Navigation top-right -->
    <nav class="alba-nav" aria-label="Navigation principale">
      <a href={`/${langKey}/#selection`} class="alba-nav-link">{t.nav_selection}</a>
      <a href={`/${langKey}/notre-maison`} class="alba-nav-link">{t.nav_house}</a>
      <a href={`/${langKey}/off-market`} class="alba-nav-link">{t.nav_offmarket}</a>
      <a href={`/${langKey}/estimation-discrete`} class="alba-nav-link">{t.nav_estimation}</a>
      <a href={`/${langKey}/demande-privee`} class="alba-nav-link alba-nav-cta">{t.nav_request}</a>
    </nav>

    <!-- Language top-right (très discret) -->
    <div class="alba-lang" id="alba-lang">
      <button type="button" class="alba-lang-btn" id="alba-lang-btn" aria-haspopup="true" aria-expanded="false">
        {langKey.toUpperCase()}
      </button>
      <div class="alba-lang-menu hidden" id="alba-lang-menu" role="menu">
        {Object.keys(languages).map((key) => (
          <a
            href={pathWithoutLang ? `/${key}/${pathWithoutLang}` : `/${key}/`}
            class={`alba-lang-opt ${key === langKey ? 'active' : ''}`}
            role="menuitem"
          >
            {key.toUpperCase()}
          </a>
        ))}
      </div>
    </div>

    <!-- Mobile burger -->
    <button type="button" class="alba-burger" id="alba-burger" aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile menu fullscreen -->
<div class="alba-mobile" id="alba-mobile" aria-hidden="true">
  <button type="button" class="alba-mobile-close" id="alba-mobile-close" aria-label="Fermer">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/>
    </svg>
  </button>
  <nav class="alba-mobile-nav">
    <a href={`/${langKey}/#selection`} class="alba-mobile-link" data-close>{t.nav_selection}</a>
    <a href={`/${langKey}/notre-maison`} class="alba-mobile-link" data-close>{t.nav_house}</a>
    <a href={`/${langKey}/off-market`} class="alba-mobile-link" data-close>{t.nav_offmarket}</a>
    <a href={`/${langKey}/estimation-discrete`} class="alba-mobile-link" data-close>{t.nav_estimation}</a>
    <a href={`/${langKey}/demande-privee`} class="alba-mobile-link" data-close>{t.nav_request}</a>
  </nav>
  <div class="alba-mobile-lang">
    {Object.keys(languages).map((key) => (
      <a
        href={pathWithoutLang ? `/${key}/${pathWithoutLang}` : `/${key}/`}
        class={`alba-mobile-lang-opt ${key === langKey ? 'active' : ''}`}
      >
        {key.toUpperCase()}
      </a>
    ))}
  </div>
</div>

<style>
  .alba-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 80;
    transition: background 0.6s var(--transition-slow), border-color 0.6s, padding 0.4s;
    border-bottom: 1px solid transparent;
  }
  /* MOBILE : header top caché — règle Tiago "dock mobile uniquement, jamais nav top mobile" */
  @media (max-width: 1023px) {
    .alba-header { display: none !important; }
  }

  .alba-header.overlay {
    background: transparent;
  }

  .alba-header.solid {
    background: var(--bg);
    border-bottom-color: var(--line);
  }

  .alba-header.scrolled {
    background: rgba(245, 241, 234, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--line);
  }

  [data-theme="noir"] .alba-header.scrolled {
    background: rgba(13, 13, 13, 0.92);
  }

  .alba-header-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 1.4rem clamp(1.5rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Brand */
  .alba-brand {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    color: var(--text);
  }

  .alba-header.overlay:not(.scrolled) .alba-brand {
    color: #FBF8F2;
  }

  .brand-mark {
    font-family: var(--serif-display);
    font-style: italic;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--accent);
  }

  .brand-name {
    font-family: var(--serif-display);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  /* Navigation */
  .alba-nav {
    display: none;
    align-items: center;
    gap: 2.2rem;
    margin-left: auto;
  }

  @media (min-width: 1024px) {
    .alba-nav { display: flex; }
  }

  .alba-nav-link {
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-soft);
    position: relative;
    padding: 0.4rem 0;
    transition: color 0.4s var(--transition-slow);
  }

  .alba-header.overlay:not(.scrolled) .alba-nav-link {
    color: rgba(251, 248, 242, 0.85);
  }

  .alba-nav-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--transition-slow);
  }

  .alba-nav-link:hover {
    color: var(--accent);
  }

  .alba-nav-link:hover::after {
    transform: scaleX(1);
  }

  .alba-nav-cta {
    color: var(--accent) !important;
  }

  /* Lang */
  .alba-lang {
    display: none;
    position: relative;
    margin-left: 1rem;
  }

  @media (min-width: 1024px) {
    .alba-lang { display: block; }
  }

  .alba-lang-btn {
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--text);
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    transition: all 0.4s;
  }

  .alba-header.overlay:not(.scrolled) .alba-lang-btn {
    color: #FBF8F2;
    border-color: rgba(251, 248, 242, 0.4);
  }

  .alba-lang-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .alba-lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--bg-card);
    border: 1px solid var(--line);
    min-width: 80px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  .alba-lang-menu.hidden { display: none; }

  .alba-lang-opt {
    padding: 0.7rem 1rem;
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--text-soft);
    transition: all 0.3s;
  }

  .alba-lang-opt:hover,
  .alba-lang-opt.active {
    background: var(--bg-soft);
    color: var(--accent);
  }

  /* Burger mobile */
  .alba-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    padding: 0;
    margin-left: auto;
    cursor: pointer;
  }

  @media (min-width: 1024px) {
    .alba-burger { display: none; }
  }

  .alba-burger span {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--text);
    transition: all 0.4s var(--transition-slow);
  }

  .alba-header.overlay:not(.scrolled) .alba-burger span {
    background: #FBF8F2;
  }

  /* Mobile menu */
  .alba-mobile {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: var(--bg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s var(--transition-slow);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
  }

  .alba-mobile.open {
    opacity: 1;
    pointer-events: auto;
  }

  .alba-mobile-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .alba-mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .alba-mobile-link {
    font-family: var(--serif-display);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.02em;
    transition: color 0.3s;
  }

  .alba-mobile-link:hover {
    color: var(--accent);
  }

  .alba-mobile-lang {
    margin-top: 3rem;
    display: flex;
    gap: 0.75rem;
  }

  .alba-mobile-lang-opt {
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--line-strong);
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--text-soft);
  }

  .alba-mobile-lang-opt.active {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>

<script is:inline>
  (function() {
    var header = document.getElementById('alba-header');
    var burger = document.getElementById('alba-burger');
    var mobile = document.getElementById('alba-mobile');
    var mobileClose = document.getElementById('alba-mobile-close');
    var langBtn = document.getElementById('alba-lang-btn');
    var langMenu = document.getElementById('alba-lang-menu');

    // Scroll state on header
    function onScroll() {
      if (window.scrollY > 60) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Burger
    function openMobile() {
      mobile.classList.add('open');
      mobile.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeMobile() {
      mobile.classList.remove('open');
      mobile.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    if (burger) burger.addEventListener('click', openMobile);
    if (mobileClose) mobileClose.addEventListener('click', closeMobile);
    document.querySelectorAll('[data-close]').forEach(function(el){
      el.addEventListener('click', closeMobile);
    });
    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape' && mobile.classList.contains('open')) closeMobile();
    });

    // Lang dropdown
    if (langBtn && langMenu) {
      langBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var hidden = langMenu.classList.contains('hidden');
        langMenu.classList.toggle('hidden', !hidden);
        langBtn.setAttribute('aria-expanded', String(hidden));
      });
      document.addEventListener('click', function() {
        langMenu.classList.add('hidden');
        langBtn.setAttribute('aria-expanded', 'false');
      });
    }
  })();
</script>
