---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { translations, languages } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

const heroLines = t.hero_title ? t.hero_title.split('\n') : ['ESTATO'];

const properties = [
  {
    slug: 'villa-moderne-cote-azur',
    title: 'Villa Moderne — Côte d\'Azur',
    location: 'Nice, France',
    price: '1 250 000 €',
    beds: 5,
    baths: 3,
    sqm: 320,
    badge: 'exclusive',
    image: 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'appartement-haussmannien-paris',
    title: 'Appartement Haussmannien',
    location: 'Paris 8e, France',
    price: '890 000 €',
    beds: 3,
    baths: 2,
    sqm: 145,
    badge: 'sale',
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'penthouse-vue-mer-barcelone',
    title: 'Penthouse Vue Mer',
    location: 'Barcelone, Espagne',
    price: '2 100 €/mois',
    beds: 2,
    baths: 2,
    sqm: 110,
    badge: 'rent',
    image: 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'villa-contemporaine-geneve',
    title: 'Villa Contemporaine',
    location: 'Genève, Suisse',
    price: '3 400 000 CHF',
    beds: 6,
    baths: 4,
    sqm: 480,
    badge: 'new',
    image: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'appartement-vue-tage-lisbonne',
    title: 'Appartement Vue Tage',
    location: 'Lisbonne, Portugal',
    price: '650 000 €',
    beds: 2,
    baths: 1,
    sqm: 98,
    badge: 'sale',
    image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'villa-piscine-marbella',
    title: 'Villa Piscine — Marbella',
    location: 'Marbella, Espagne',
    price: '1 800 000 €',
    beds: 5,
    baths: 4,
    sqm: 380,
    badge: 'exclusive',
    image: 'https://images.unsplash.com/photo-1600047509807-ba8f99d2cdde?w=800&h=600&fit=crop&q=80',
  },
];
---

<BaseLayout title={t.meta_title} description={t.meta_description} lang={langKey}>
  <Header lang={langKey} />

  <!-- ═══════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════ -->
  <section class="hero-section" aria-label="Hero">
    <!-- Background slideshow with Ken Burns -->
    <div class="hero-bg">
      <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1920&h=1080&fit=crop&q=80');animation-delay:0s"></div>
      <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=1920&h=1080&fit=crop&q=80');animation-delay:6s"></div>
      <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1920&h=1080&fit=crop&q=80');animation-delay:12s"></div>
      <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1920&h=1080&fit=crop&q=80');animation-delay:18s"></div>
      <!-- Vignette layers -->
      <div class="hero-vignette"></div>
      <div class="hero-bg-overlay"></div>
    </div>

    <!-- Decorative left edge -->
    <div class="hero-edge-left" aria-hidden="true">
      <span class="edge-text">ESTATO ◆ LUXURY REAL ESTATE</span>
      <span class="edge-line"></span>
    </div>

    <!-- ESTATO brand — fills top space like a logo -->
    <div class="hero-brand-wrap" id="hero-brand-obs" aria-hidden="true">
      <div class="hero-brand-inner">
        <span class="hero-brand-name">ESTATO</span><span class="hero-brand-dot">◆</span>
      </div>
    </div>

    <!-- Hero content -->
    <div class="hero-content">
      <div class="hero-inner">
        <!-- Gold pre-title bar -->
        <div class="hero-pretitle">
          <span class="pretitle-dot">◆</span>
          <span class="pretitle-text">{t.hero_label}</span>
          <span class="pretitle-dot">◆</span>
        </div>

        <h1 class="hero-title">
          {heroLines.map((line, i) => (
            <span class={`hero-line ${i === 1 ? 'hero-line-accent' : ''}`}>{line}</span>
          ))}
        </h1>

        <!-- Gold divider under title -->
        <div class="hero-divider" aria-hidden="true">
          <span class="divider-line"></span>
          <span class="divider-diamond">◆</span>
          <span class="divider-line"></span>
        </div>

        <p class="hero-subtitle">{t.hero_subtitle}</p>

        <div class="hero-btns">
          <a href={`#properties`} class="liquid-btn primary">{t.hero_cta}</a>
          <a href={`mailto:contact@estato.com`} class="liquid-btn ghost">{t.hero_cta2}</a>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-number">200+</span>
          <span class="stat-label">{t.stat_properties || 'Propriétés'}</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-number">12</span>
          <span class="stat-label">{t.stat_countries || 'Pays'}</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-number">98%</span>
          <span class="stat-label">{t.stat_satisfaction || 'Satisfaction'}</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-number">15</span>
          <span class="stat-label">{t.stat_years || 'Années'}</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator — mouse icon -->
    <a href="#properties" class="scroll-indicator" aria-label="Défiler">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <span class="scroll-label">SCROLL</span>
    </a>
  </section>

  <!-- ═══════════════════════════════════
       PROPERTIES SECTION
  ═══════════════════════════════════ -->
  <section id="properties" class="properties-section">
    <div class="section-wrap">
      <!-- Section header -->
      <div class="section-header fade-up">
        <p class="eyebrow">{t.featured_title}</p>
        <p class="section-subtitle">{t.featured_subtitle}</p>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs fade-up">
        <button type="button" class="filter-tab active" data-filter="all">{t.filter_all}</button>
        <button type="button" class="filter-tab" data-filter="sale">{t.filter_sale}</button>
        <button type="button" class="filter-tab" data-filter="rent">{t.filter_rent}</button>
        <button type="button" class="filter-tab" data-filter="new">{t.filter_new}</button>
        <button type="button" class="filter-tab" data-filter="exclusive">{t.badge_exclusive}</button>
      </div>

      <!-- Properties grid -->
      <div class="properties-grid" id="properties-grid">
        {properties.map((property) => (
          <div class="property-item" data-badge={property.badge}>
            <PropertyCard property={property} lang={langKey} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CTA SECTION
  ═══════════════════════════════════ -->
  <section class="cta-section">
    <div class="cta-inner fade-up">
      <div class="cta-content">
        <p class="eyebrow" style="justify-content:center">{t.badge_exclusive}</p>
        <h2 class="cta-title">{t.cta_section_title}</h2>
        <p class="cta-subtitle">{t.cta_section_subtitle}</p>
        <a href={`mailto:contact@estato.com`} class="liquid-btn primary cta-btn">{t.cta_btn}</a>
      </div>
      <!-- Decorative image -->
      <div class="cta-image-wrap">
        <img
          src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop&q=80"
          alt=""
          class="cta-image"
          loading="lazy"
          width="600"
          height="400"
        />
        <div class="cta-image-overlay"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       FOOTER
  ═══════════════════════════════════ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">ESTATO</span>
        <span class="footer-logo-dot">◆</span>
        <p class="footer-tagline">{t.footer_tagline}</p>
      </div>

      <div class="footer-links">
        <a href={`/${langKey}/#properties`}>{t.nav_properties}</a>
        <a href={`mailto:${t.footer_contact}`}>{t.footer_contact}</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{t.footer_rights}</span>
      <span class="footer-by">
        {t.footer_by} <a href="https://ultras-sites.com" target="_blank" rel="noopener" class="footer-us-link">Ultras-Sites</a>
      </span>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ══════════════════════════════════════
     HERO — PREMIUM LUXURY
  ══════════════════════════════════════ */
  .hero-section {
    position: relative;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding-top: 10vh; /* space for mobile header */
  }

  @media (min-width: 768px) {
    .hero-section {
      padding-top: 0;
    }
  }

  /* ── BACKGROUND SLIDESHOW ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-slide {
    position: absolute;
    inset: -5%; /* extra space for Ken Burns scale */
    background-size: cover;
    background-position: center;
    opacity: 0;
    animation: heroFade 24s infinite, kenBurns 24s infinite;
  }

  @keyframes heroFade {
    0%   { opacity: 0; }
    4%   { opacity: 1; }
    25%  { opacity: 1; }
    33%  { opacity: 0; }
    100% { opacity: 0; }
  }

  @keyframes kenBurns {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.08) translate(-1%, 1%); }
  }

  /* Vignette (dark edges) */
  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, var(--hero-overlay) 100%);
    z-index: 1;
  }

  /* Gradient overlay — rich, dramatic */
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(to bottom,
        rgba(var(--accent-rgb), 0.1) 0%,
        transparent 30%,
        transparent 55%,
        var(--hero-overlay) 85%,
        var(--bg) 100%
      ),
      linear-gradient(to right,
        var(--hero-overlay) 0%,
        transparent 30%,
        transparent 70%,
        var(--hero-overlay) 100%
      );
  }

  /* ── DECORATIVE LEFT EDGE ── */
  .hero-edge-left {
    display: none;
    position: absolute;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 1024px) {
    .hero-edge-left { display: flex; }
  }

  .edge-text {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-size: 0.5rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(201, 168, 76, 0.5);
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
  }

  .edge-line {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.4), transparent);
  }

  /* ── HERO BRAND (ESTATO large logo in top space) ── */
  .hero-brand-wrap {
    top: 7vh;
    left: 0;
    right: 0;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .hero-brand-wrap {
      top: 10vh;
    }
  }

  .hero-brand-inner {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .hero-brand-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 15vw, 15rem);
    letter-spacing: 0.05em;
    color: var(--text);
    opacity: 0.08;
    line-height: 1;
  }

  .hero-brand-dot {
    color: var(--accent);
    font-size: 0.7rem;
    vertical-align: super;
    margin-left: 0.2em;
  }

  /* ── HERO CONTENT ── */
  .hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 1400px;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 4vh, 2.5rem);
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: 0 3rem;
    }
  }

  .hero-inner {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Pre-title (replaces eyebrow) */
  .hero-pretitle {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: clamp(1.2rem, 3vh, 2rem);
    padding: 0.55rem 1.5rem;
    background: var(--glass-bg);
    border: 1px solid var(--accent);
    border-radius: 100px;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.15);
  }

  .pretitle-dot {
    color: var(--accent);
    font-size: 0.35rem;
    opacity: 0.8;
  }

  .pretitle-text {
    font-family: 'Outfit', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* Hero title */
  .hero-title {
    display: flex;
    flex-direction: column;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.88;
    letter-spacing: 0.01em;
    margin-bottom: clamp(1.2rem, 3vh, 2rem);
  }

  .hero-line {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--accent);
    text-shadow: none;
  }

  /* Gold divider */
  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: clamp(1.2rem, 3vh, 2rem);
  }

  .divider-line {
    height: 1px;
    width: 60px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.6));
  }

  .divider-line:last-child {
    background: linear-gradient(to left, transparent, rgba(201,168,76,0.6));
  }

  .divider-diamond {
    color: var(--accent);
    font-size: 0.45rem;
    opacity: 0.8;
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text2);
    line-height: 1.6;
    font-weight: 300;
    margin-bottom: clamp(1.5rem, 4vh, 2.5rem);
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: 0.02em;
  }

  .hero-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* ══════════════════════════════════════
     HERO ENTRY ANIMATIONS — CSS only
  ══════════════════════════════════════ */

  @keyframes brandDrop {
    from { opacity: 0; transform: translateY(-20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pretitleSlide {
    from { opacity: 0; transform: translateX(-15px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes lineReveal {
    from { clip-path: inset(100% 0 0 0); transform: translateY(40px); opacity: 0; }
    to   { clip-path: inset(0% 0 0 0);   transform: translateY(0);    opacity: 1; }
  }

  @keyframes dividerExpand {
    from { opacity: 0; transform: scaleX(0); }
    to   { opacity: 1; transform: scaleX(1); }
  }

  @keyframes fadeRise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes btnEntrance {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Shimmer on accent line */
  @keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
  }

  /* Element animations */
  .hero-brand-wrap {
    animation: brandDrop 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }

  .hero-pretitle {
    animation: pretitleSlide 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }

  .hero-line:not(.hero-line-accent) {
    animation: lineReveal 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.65s both;
  }

  .hero-line-accent {
    animation: lineReveal 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.85s both,
               shimmer 4s linear 1.8s infinite;
    color: var(--text);
    -webkit-text-stroke: 0;
    text-stroke: 0;
    background: linear-gradient(90deg, var(--accent-dark), var(--accent) 30%, #f5d98b 50%, var(--accent) 70%, var(--accent-dark));
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-divider {
    animation: dividerExpand 0.6s cubic-bezier(0.22, 1, 0.36, 1) 1.1s both;
    transform-origin: center;
  }

  .hero-subtitle {
    animation: fadeRise 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1.25s both;
  }

  .hero-btns {
    animation: btnEntrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.45s both;
  }

  @keyframes statsRise {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── STATS STRIP ── */
  .hero-stats {
    animation: statsRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.65s both;
    display: flex;
    align-items: stretch;
    gap: 0;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur) saturate(180%);
    -webkit-backdrop-filter: var(--glass-blur) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    overflow: hidden;
    margin-top: clamp(1rem, 3vh, 2.5rem);
    margin-bottom: calc(20px + env(safe-area-inset-bottom)); /* reduced to improve centering */
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: clamp(1rem, 2vh, 1.5rem) clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
  }

  .stat-item::before {
    content: '';
    position: absolute;
    inset: 20% 0;
    left: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.2), transparent);
  }

  .stat-item:first-child::before { display: none; }

  .stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: 0.05em;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.52rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    font-family: 'Outfit', sans-serif;
    white-space: nowrap;
  }

  .stat-sep { display: none; } /* hidden — use ::before on stat-item instead */

  @media (max-width: 600px) {
    .hero-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-radius: 16px;
    }
    .stat-item {
      padding: 1.2rem 1rem;
      border-bottom: 1px solid rgba(201,168,76,0.1);
    }
    .stat-item:nth-child(odd)::before { display: none; }
    .stat-item:nth-child(even)::before { display: block; }
    .stat-number { font-size: 1.6rem; }
  }

  /* ── SCROLL INDICATOR — MOUSE ICON ── */
  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    animation: scrollFloat 3s ease-in-out infinite;
  }

  @keyframes scrollFloat {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.7; }
    50%       { transform: translateX(-50%) translateY(6px); opacity: 1; }
  }

  .scroll-mouse {
    width: 22px;
    height: 34px;
    border: 1.5px solid rgba(201,168,76,0.5);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 5px;
  }

  .scroll-wheel {
    width: 3px;
    height: 6px;
    background: var(--accent);
    border-radius: 2px;
    animation: scrollWheelMove 2s ease-in-out infinite;
  }

  @keyframes scrollWheelMove {
    0%, 100% { transform: translateY(0); opacity: 1; }
