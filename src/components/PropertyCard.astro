---
import { translations } from '../i18n/translations';

interface Props {
  property: {
    slug: string;
    title: string;
    location: string;
    price: string;
    beds: number;
    baths: number;
    sqm: number;
    badge: string;
    image: string;
  };
  lang?: string;
}

const { property, lang = 'fr' } = Astro.props;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};
---

<article class="property-card fade-up">
  <div class="card-image-wrap">
    <img
      src={property.image}
      alt={property.title}
      class="card-img"
      loading="lazy"
      width="400"
      height="300"
    />
    <div class="card-gradient-overlay"></div>
    <span class={`property-badge ${property.badge === 'exclusive' ? 'badge-exclusive' : property.badge === 'new' ? 'badge-new' : property.badge === 'rent' ? 'badge-rent' : 'badge-sale'}`}>
      {property.badge === 'exclusive' ? t.badge_exclusive : property.badge === 'new' ? t.badge_new : property.badge === 'rent' ? t.badge_rent : t.badge_sale}
    </span>
    <div class="card-price-overlay">
      <span class="price-tag">{property.price}</span>
    </div>
  </div>

  <div class="card-body">
    <h3 class="card-title">{property.title}</h3>
    <p class="card-location">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"/>
      </svg>
      {property.location}
    </p>

    <div class="card-specs">
      <span class="spec-item">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
        </svg>
        {property.beds} {t.prop_beds}
      </span>
      <span class="spec-item">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33"/>
        </svg>
        {property.baths}
      </span>
      <span class="spec-item">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
        </svg>
        {property.sqm} m²
      </span>
    </div>

    <a
      href={`mailto:contact@estato.com?subject=${encodeURIComponent(property.title)}`}
      class="card-contact-btn"
    >
      {t.prop_contact}
    </a>
  </div>

  <div class="card-shine" aria-hidden="true"></div>
</article>

<style>
  .property-card {
    position: relative;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur) saturate(180%);
    -webkit-backdrop-filter: var(--glass-blur) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: transform 0.4s var(--transition-spring), border-color 0.4s, box-shadow 0.4s;
    box-shadow:
      inset 0 1px 1px var(--glass-shine),
      0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .property-card:hover {
    transform: translateY(-6px);
    border-color: rgba(var(--accent-rgb), 0.4);
    box-shadow:
      inset 0 1px 1px var(--glass-shine),
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(var(--accent-rgb), 0.15),
      0 0 30px rgba(var(--accent-rgb), 0.12);
  }

  .card-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.03) 50%,
      transparent 60%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
    transform: translateX(-100%);
  }

  .property-card:hover .card-shine {
    opacity: 1;
    transform: translateX(100%);
    transition: transform 0.7s ease, opacity 0.3s;
  }

  /* Image */
  .card-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .property-card:hover .card-img {
    transform: scale(1.06);
  }

  .card-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--hero-overlay) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Badge */
  .property-badge {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    z-index: 2;
    font-family: 'Outfit', sans-serif;
  }

  .badge-exclusive {
    background: var(--accent);
    color: #000;
    box-shadow: 0 2px 12px rgba(var(--accent-rgb), 0.5);
  }

  .badge-new {
    background: rgba(6, 182, 212, 0.9);
    color: #000;
  }

  .badge-rent {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
  }

  .badge-sale {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
  }

  /* Price overlay */
  .card-price-overlay {
    position: absolute;
    bottom: 0.875rem;
    left: 0.875rem;
    right: 0.875rem;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    z-index: 2;
  }

  .price-tag {
    font-family: 'Bebas Neue', 'Outfit', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--accent);
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }

  /* Card body */
  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-location {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--text3);
    font-family: 'Outfit', sans-serif;
  }

  /* Specs row */
  .card-specs {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    margin: 0.1rem 0;
  }

  .spec-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
    white-space: nowrap;
  }

  /* Contact button */
  .card-contact-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-btn);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: 'Outfit', sans-serif;
    background: transparent;
    transition: all 0.3s var(--transition-spring);
    margin-top: 0.25rem;
    cursor: pointer;
  }

  .card-contact-btn:hover {
    background: rgba(var(--accent-rgb), 0.12);
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(var(--accent-rgb), 0.25);
  }
</style>
