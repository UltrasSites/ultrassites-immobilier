---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { translations, languages, getEstates } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

const estates = getEstates(t);

const heroBg = 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=2400&h=1600&fit=crop&q=80&auto=format';
---

<BaseLayout title={t.meta_title} description={t.meta_description} lang={langKey}>
  <Header lang={langKey} variant="overlay" />

  <!-- ═══════════════════════════════════
       HERO — Cinéma plein écran
  ═══════════════════════════════════ -->
  <section class="alba-hero">
    <div class="alba-hero-img-wrap">
      <img src={heroBg} alt="" class="alba-hero-img" fetchpriority="high" />
      <div class="alba-hero-veil"></div>
    </div>

    <div class="alba-hero-content">
      <div class="alba-hero-quote">
        <span class="alba-hero-rule"></span>
        <p class="italic-quote">{t.hero_quote}</p>
      </div>
    </div>

    <a href="#selection" class="alba-hero-cta" aria-label={t.hero_cta_discover}>
      <span>{t.hero_cta_discover}</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M7 1v12M2 8l5 5 5-5" stroke="currentColor" stroke-width="1"/>
      </svg>
    </a>
  </section>

  <!-- ═══════════════════════════════════
       SÉLECTION
  ═══════════════════════════════════ -->
  <section id="selection" class="section">
    <div class="container">
      <div class="selection-head">
        <p class="eyebrow fade-in">{t.selection_eyebrow}</p>
        <h2 class="selection-title fade-in delay-1">
          {t.selection_title.split('\n').map((line, i) => <span class="block-line">{line}</span>)}
        </h2>
        <div class="rule fade-in delay-2"></div>
        <p class="selection-lead fade-in delay-2">{t.selection_lead}</p>
      </div>

      <div class="estates-grid">
        {estates.map((estate, i) => (
          <PropertyCard estate={estate} lang={langKey} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       OFF-MARKET — bloc invitation
  ═══════════════════════════════════ -->
  <section class="alba-offmarket section">
    <div class="container-narrow">
      <p class="eyebrow fade-in" style="text-align:center">{t.offmarket_eyebrow}</p>
      <h2 class="alba-offmarket-title fade-in delay-1">{t.offmarket_title}</h2>
      <div class="rule rule-center fade-in delay-2"></div>
      <p class="alba-offmarket-lead fade-in delay-2">{t.offmarket_lead}</p>
      <div class="alba-offmarket-cta fade-in delay-3">
        <a href={`/${langKey}/off-market`} class="cta-ghost">
          <span>{t.nav_offmarket}</span>
          <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <Footer lang={langKey} />
</BaseLayout>

<style>
  /* ═══ HERO ═══ */
  .alba-hero {
    position: relative;
    height: 100dvh;
    min-height: 640px;
    width: 100%;
    overflow: hidden;
    background: #1a1a1a;
  }

  .alba-hero-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .alba-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    animation: heroKenBurns 18s ease-out forwards;
  }

  @keyframes heroKenBurns {
    from { transform: scale(1.02); }
    to { transform: scale(1.08); }
  }

  .alba-hero-veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(0,0,0,0.35) 0%,
        rgba(0,0,0,0.15) 30%,
        rgba(0,0,0,0.25) 70%,
        rgba(0,0,0,0.55) 100%);
  }

  .alba-hero-content {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    padding: clamp(2rem, 6vw, 5rem);
    max-width: 600px;
  }

  .alba-hero-quote {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    color: #FBF8F2;
  }

  .alba-hero-rule {
    width: 60px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .alba-hero-quote p {
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    line-height: 1.4;
    letter-spacing: 0.005em;
    color: #FBF8F2;
    animation: heroQuoteFade 1.6s var(--transition-slow) 0.5s both;
  }

  @keyframes heroQuoteFade {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .alba-hero-cta {
    position: absolute;
    bottom: clamp(2rem, 5vw, 4rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    color: #FBF8F2;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(251, 248, 242, 0.4);
    transition: border-color 0.4s, color 0.4s;
    animation: heroCtaFade 1.4s var(--transition-slow) 1.2s both;
  }

  .alba-hero-cta:hover {
    color: var(--accent-soft);
    border-bottom-color: var(--accent-soft);
  }

  .alba-hero-cta svg {
    animation: heroArrowBob 2.5s ease-in-out infinite;
  }

  @keyframes heroArrowBob {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50% { transform: translateY(4px); opacity: 1; }
  }

  @keyframes heroCtaFade {
    from { opacity: 0; transform: translate(-50%, 20px); }
    to { opacity: 1; transform: translate(-50%, 0); }
  }

  @media (max-width: 768px) {
    .alba-hero-content {
      max-width: 90%;
      padding-bottom: 7rem;
    }
    .alba-hero-quote {
      gap: 1rem;
    }
    .alba-hero-rule {
      width: 40px;
    }
  }

  /* ═══ SÉLECTION ═══ */
  .selection-head {
    max-width: 760px;
    margin: 0 auto clamp(4rem, 8vw, 7rem);
    text-align: center;
  }

  .selection-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.05;
  }

  .selection-title .block-line {
    display: block;
  }

  .selection-head .rule {
    margin-left: auto;
    margin-right: auto;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .selection-lead {
    font-family: var(--serif-text);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-soft);
    max-width: 580px;
    margin: 0 auto;
  }

  .estates-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: clamp(2rem, 5vw, 4rem);
    row-gap: clamp(4rem, 8vw, 7rem);
  }

  @media (max-width: 700px) {
    .estates-grid {
      grid-template-columns: 1fr;
      row-gap: 3.5rem;
    }
  }

  /* ═══ OFF-MARKET BLOC ═══ */
  .alba-offmarket {
    background: var(--bg-soft);
    text-align: center;
  }

  .alba-offmarket-title {
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    max-width: 720px;
    margin: 0 auto;
  }

  .alba-offmarket-lead {
    font-family: var(--serif-text);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-soft);
    max-width: 540px;
    margin: 0 auto 2.5rem;
  }

  .alba-offmarket-cta {
    display: flex;
    justify-content: center;
  }
</style>
