<script is:inline>
  // Filter tabs
  (function() {
    var tabs = document.querySelectorAll('.filter-tab');
    var items = document.querySelectorAll('.property-item');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var filter = tab.getAttribute('data-filter');

        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');

        items.forEach(function(item) {
          if (filter === 'all') {
            item.classList.remove('hidden');
          } else {
            var badge = item.getAttribute('data-badge');
            if (badge === filter) {
              item.classList.remove('hidden');
            } else {
              item.classList.add('hidden');
            }
          }
        });
      });
    });
  })();

  // IntersectionObserver — show header logo when ESTATO brand exits viewport
  (function() {
    var brandObs = document.getElementById('hero-brand-obs');
    var headerLogo = document.getElementById('header-logo-link');
    if (!brandObs || !headerLogo) return;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) {
          // brand has left viewport — show header logo
          headerLogo.classList.add('logo-visible');
        } else {
          // brand is back in viewport — hide header logo
          headerLogo.classList.remove('logo-visible');
        }
      });
    }, { threshold: 0 });

    observer.observe(brandObs);
  })();
</script>
