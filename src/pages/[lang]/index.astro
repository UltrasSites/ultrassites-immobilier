---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { translations, languages } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

const heroLines = t.hero_title ? t.hero_title.split('\n') : ['ESTATO'];

const properties = [
  {
    slug: 'villa-moderne-cote-azur',
    title: 'Villa Moderne — Côte d\'Azur',
    location: 'Nice, France',
    price: '1 250 000 €',
    beds: 5,
    baths: 3,
    sqm: 320,
    badge: 'exclusive',
    image: 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'appartement-haussmannien-paris',
    title: 'Appartement Haussmannien',
    location: 'Paris 8e, France',
    price: '890 000 €',
    beds: 3,
    baths: 2,
    sqm: 145,
    badge: 'sale',
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'penthouse-vue-mer-barcelone',
    title: 'Penthouse Vue Mer',
    location: 'Barcelone, Espagne',
    price: '2 100 €/mois',
    beds: 2,
    baths: 2,
    sqm: 110,
    badge: 'rent',
    image: 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'villa-contemporaine-geneve',
    title: 'Villa Contemporaine',
    location: 'Genève, Suisse',
    price: '3 400 000 CHF',
    beds: 6,
    baths: 4,
    sqm: 480,
    badge: 'new',
    image: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'appartement-vue-tage-lisbonne',
    title: 'Appartement Vue Tage',
    location: 'Lisbonne, Portugal',
    price: '650 000 €',
    beds: 2,
    baths: 1,
    sqm: 98,
    badge: 'sale',
    image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&h=600&fit=crop&q=80',
  },
  {
    slug: 'villa-piscine-marbella',
    title: 'Villa Piscine — Marbella',
    location: 'Marbella, Espagne',
    price: '1 800 000 €',
    beds: 5,
    baths: 4,
    sqm: 380,
    badge: 'exclusive',
    image: 'https://images.unsplash.com/photo-1600047509807-ba8f99d2cdde?w=800&h=600&fit=crop&q=80',
  },
];
---

<BaseLayout title={t.meta_title} description={t.meta_description} lang={langKey}>
  <Header lang={langKey} />

  <!-- ═══════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════ -->
  <section class="hero-section" aria-label="Hero">
    <!-- Background image -->
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1920&h=1080&fit=crop&q=80"
        alt=""
        class="hero-bg-img"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
      <div class="hero-bg-overlay"></div>
    </div>

    <!-- Hero content -->
    <div class="hero-content">
      <div class="hero-inner fade-up">
        <p class="hero-eyebrow">
          <span class="eyebrow-line"></span>
          {t.hero_label}
          <span class="eyebrow-line"></span>
        </p>

        <h1 class="hero-title">
          {heroLines.map((line, i) => (
            <span class={`hero-line ${i === 1 ? 'hero-line-accent' : ''}`}>{line}</span>
          ))}
        </h1>

        <p class="hero-subtitle">{t.hero_subtitle}</p>

        <div class="hero-btns">
          <a href={`#properties`} class="liquid-btn primary">{t.hero_cta}</a>
          <a href={`mailto:contact@estato.com`} class="liquid-btn ghost">{t.hero_cta2}</a>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="hero-stats fade-up">
        <div class="stat-item">
          <span class="stat-number">200+</span>
          <span class="stat-label">Propriétés</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-number">12</span>
          <span class="stat-label">Pays</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <span class="stat-number">98%</span>
          <span class="stat-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" aria-hidden="true">
      <div class="scroll-dot"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       PROPERTIES SECTION
  ═══════════════════════════════════ -->
  <section id="properties" class="properties-section">
    <div class="section-wrap">
      <!-- Section header -->
      <div class="section-header fade-up">
        <p class="eyebrow">{t.featured_title}</p>
        <p class="section-subtitle">{t.featured_subtitle}</p>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs fade-up">
        <button type="button" class="filter-tab active" data-filter="all">{t.filter_all}</button>
        <button type="button" class="filter-tab" data-filter="sale">{t.filter_sale}</button>
        <button type="button" class="filter-tab" data-filter="rent">{t.filter_rent}</button>
        <button type="button" class="filter-tab" data-filter="new">{t.filter_new}</button>
        <button type="button" class="filter-tab" data-filter="exclusive">{t.badge_exclusive}</button>
      </div>

      <!-- Properties grid -->
      <div class="properties-grid" id="properties-grid">
        {properties.map((property) => (
          <div class="property-item" data-badge={property.badge}>
            <PropertyCard property={property} lang={langKey} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CTA SECTION
  ═══════════════════════════════════ -->
  <section class="cta-section">
    <div class="cta-inner fade-up">
      <div class="cta-content">
        <p class="eyebrow" style="justify-content:center">{t.badge_exclusive}</p>
        <h2 class="cta-title">{t.cta_section_title}</h2>
        <p class="cta-subtitle">{t.cta_section_subtitle}</p>
        <a href={`mailto:contact@estato.com`} class="liquid-btn primary cta-btn">{t.cta_btn}</a>
      </div>
      <!-- Decorative image -->
      <div class="cta-image-wrap">
        <img
          src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop&q=80"
          alt=""
          class="cta-image"
          loading="lazy"
          width="600"
          height="400"
        />
        <div class="cta-image-overlay"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       FOOTER
  ═══════════════════════════════════ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">ESTATO</span>
        <span class="footer-logo-dot">◆</span>
        <p class="footer-tagline">{t.footer_tagline}</p>
      </div>

      <div class="footer-links">
        <a href={`/${langKey}/#properties`}>{t.nav_properties}</a>
        <a href={`mailto:${t.footer_contact}`}>{t.footer_contact}</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{t.footer_rights}</span>
      <span class="footer-by">
        {t.footer_by} <a href="https://ultras-sites.com" target="_blank" rel="noopener" class="footer-us-link">Ultras-Sites</a>
      </span>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .hero-section {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(1,2,8,0.55) 0%,
      rgba(1,2,8,0.35) 40%,
      rgba(1,2,8,0.7) 80%,
      rgba(1,2,8,1) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4rem;
    padding-top: 8rem;
    padding-bottom: 6rem;
  }

  .hero-inner {
    max-width: 700px;
  }

  /* Hero eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2rem;
    font-family: 'Outfit', sans-serif;
  }

  .eyebrow-line {
    display: block;
    width: 36px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* Hero title */
  .hero-title {
    display: flex;
    flex-direction: column;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.92;
    letter-spacing: 0.03em;
    margin-bottom: 2rem;
  }

  .hero-line {
    display: block;
    color: var(--text);
  }

  .hero-line-accent {
    color: var(--accent);
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--text2);
    line-height: 1.6;
    font-weight: 300;
    margin-bottom: 2.5rem;
    max-width: 520px;
  }

  .hero-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Stats strip */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    box-shadow: inset 0 1px 1px var(--glass-shine), 0 8px 32px rgba(0,0,0,0.4);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.05em;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    font-family: 'Outfit', sans-serif;
  }

  .stat-sep {
    width: 1px;
    height: 36px;
    background: var(--glass-border);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.4; }
  }

  /* ══════════════════════════════════════
     PROPERTIES SECTION
  ══════════════════════════════════════ */
  .properties-section {
    padding: 6rem 0 8rem;
  }

  .section-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header .eyebrow {
    justify-content: center;
  }

  /* Filter tabs */
  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .filter-tab {
    padding: 0.55rem 1.4rem;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: 'Outfit', sans-serif;
    cursor: pointer;
    border: 1px solid var(--glass-border);
    background: transparent;
    color: var(--text3);
    transition: all 0.3s var(--transition-spring);
  }

  .filter-tab:hover {
    border-color: rgba(var(--accent-rgb), 0.4);
    color: var(--text2);
  }

  .filter-tab.active {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    border-color: var(--accent);
    color: #000;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.35);
  }

  /* Properties grid */
  .properties-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 900px) {
    .properties-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .properties-grid {
      grid-template-columns: 1fr;
    }
  }

  .property-item.hidden {
    display: none;
  }

  /* ══════════════════════════════════════
     CTA SECTION
  ══════════════════════════════════════ */
  .cta-section {
    padding: 2rem 2rem 6rem;
  }

  .cta-inner {
    max-width: 1200px;
    margin: 0 auto;
    border-radius: 28px;
    overflow: hidden;
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 400px;
    border: 1px solid var(--glass-border);
    background: var(--bg2);
  }

  @media (max-width: 768px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }
    .cta-image-wrap {
      display: none;
    }
  }

  .cta-content {
    padding: 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    position: relative;
    z-index: 2;
  }

  .cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.1;
  }

  .cta-subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    color: var(--text2);
    line-height: 1.6;
    max-width: 420px;
  }

  .cta-btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .cta-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .cta-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cta-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--bg2) 0%, transparent 40%);
  }

  /* ══════════════════════════════════════
     FOOTER
  ══════════════════════════════════════ */
  .site-footer {
    border-top: 1px solid var(--glass-border);
    padding: 3rem 2rem 2rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: 1.5rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo-wrap {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    letter-spacing: 0.2em;
    color: var(--text);
    line-height: 1;
  }

  .footer-logo-dot {
    color: var(--accent);
    font-size: 0.5rem;
    margin-left: 0.3rem;
  }

  .footer-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 0.9rem;
    color: var(--text3);
    margin-top: 0.25rem;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-end;
  }

  .footer-links a {
    font-size: 0.75rem;
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
    transition: color 0.3s;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.68rem;
    color: var(--text3);
    font-family: 'Outfit', sans-serif;
  }

  .footer-by { display: flex; gap: 0.3rem; }

  .footer-us-link {
    color: var(--accent);
    transition: opacity 0.3s;
  }

  .footer-us-link:hover { opacity: 0.7; }
</style>

<script is:inline>
  // Filter tabs
  (function() {
    var tabs = document.querySelectorAll('.filter-tab');
    var items = document.querySelectorAll('.property-item');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var filter = tab.getAttribute('data-filter');

        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');

        items.forEach(function(item) {
          if (filter === 'all') {
            item.classList.remove('hidden');
          } else {
            var badge = item.getAttribute('data-badge');
            if (badge === filter) {
              item.classList.remove('hidden');
            } else {
              item.classList.add('hidden');
            }
          }
        });
      });
    });
  })();
</script>
