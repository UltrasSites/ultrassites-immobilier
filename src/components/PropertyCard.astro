---
interface Props {
  estate: {
    slug: string;
    name: string;
    city: string;
    price: string;
    cover: string;
  };
  lang: string;
  index?: number;
}

const { estate, lang, index = 0 } = Astro.props;
const delayClass = `delay-${(index % 4) + 1}`;
---

<a href={`/${lang}/demeure/${estate.slug}`} class={`estate-card fade-in ${delayClass}`}>
  <div class="estate-card-img-wrap">
    <img
      src={estate.cover}
      alt={estate.name}
      class="estate-card-img"
      loading="lazy"
      width="800"
      height="1000"
    />
    <span class="estate-card-line"></span>
  </div>
  <div class="estate-card-body">
    <h3 class="estate-card-name">{estate.name}</h3>
    <p class="estate-card-city">{estate.city}</p>
    <p class="estate-card-price">{estate.price}</p>
  </div>
</a>

<style>
  .estate-card {
    display: block;
    color: var(--text);
    text-decoration: none;
    position: relative;
  }

  .estate-card-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-soft);
  }

  .estate-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s var(--transition-slow);
    will-change: transform;
  }

  .estate-card:hover .estate-card-img {
    transform: scale(1.025);
  }

  .estate-card-line {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: 0;
    background: var(--accent);
    transition: width 0.7s var(--transition-slow);
  }

  .estate-card:hover .estate-card-line {
    width: 100%;
  }

  .estate-card-body {
    padding: 1.5rem 0 0;
  }

  .estate-card-name {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 0.4rem;
    letter-spacing: -0.005em;
  }

  .estate-card-city {
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .estate-card-price {
    font-family: var(--serif-text);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-soft);
    letter-spacing: 0.04em;
  }
</style>
